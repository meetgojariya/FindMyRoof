# Database Configuration
# For PythonAnywhere, DB_HOST is usually your MySQL host like:
# yourusername.mysql.pythonanywhere-services.com
DB_HOST=your_mysql_host
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password

# Email Configuration
# Use a Gmail App Password, not your normal Gmail password.
EMAIL_ADDRESS=your_email_address@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True

# OTP Configuration
OTP_EXPIRES_MINUTES=2
BYPASS_OTP=False

# Admin Configuration
ADMIN_1_USERNAME=admin_one
ADMIN_1_EMAIL=admin1@example.com
ADMIN_1_PASSWORD=change_me
ADMIN_1_ROLE=admin

ADMIN_2_USERNAME=admin_two
ADMIN_2_EMAIL=admin2@example.com
ADMIN_2_PASSWORD=change_me
ADMIN_2_ROLE=admin

ADMIN_3_USERNAME=admin_three
ADMIN_3_EMAIL=admin3@example.com
ADMIN_3_PASSWORD=change_me
ADMIN_3_ROLE=admin

# Flask Configuration
FLASK_ENV=production
SECRET_KEY=change_this_to_a_long_random_string
